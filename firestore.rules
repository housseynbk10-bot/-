rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'housseynbk10@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- System Settings ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 

      // --- User Cart Subcollection ---
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'updatedAt'])
               && data.keys().size() >= 5 && data.keys().size() <= 6
               && data.uid == request.auth.uid
               && data.email is string && data.email.size() <= 256
               && data.displayName is string && data.displayName.size() <= 128
               && data.createdAt == request.time
               && data.updatedAt == request.time;
      }

      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'displayName', 'photoURL'])
                    && request.resource.data.updatedAt == request.time;
    }

    // --- Ads Collection ---
    match /ads/{adId} {
      allow read: if true; // Ads are public
      
      function isValidAd(data) {
        return data.keys().hasAll(['title', 'price', 'category', 'location', 'description', 'ownerId', 'ownerName', 'createdAt', 'phone', 'ownerEmail', 'imageUrl', 'images', 'isPromoted'])
               && data.title is string && data.title.size() <= 200
               && data.price is number && data.price >= 0
               && data.category is string && data.category.size() <= 100
               && data.location is string && data.location.size() <= 100
               && data.description is string && data.description.size() <= 5000
               && data.phone is string && data.phone.size() <= 50
               && data.ownerEmail is string && data.ownerEmail.size() <= 256
               && data.ownerName is string && data.ownerName.size() <= 128
               && data.imageUrl is string && data.imageUrl.size() <= 1048576
               && data.images is list && data.images.size() <= 10
               && data.isPromoted is bool
               && (data.isPromoted == false || isAdmin() || (request.method == 'update' && resource.data.isPromoted == data.isPromoted))
               && (isSignedIn() ? data.ownerId == request.auth.uid : data.ownerId == 'guest')
               && data.createdAt == request.time;
      }

      allow create: if isValidAd(request.resource.data);
      allow update: if (isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid))
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'price', 'category', 'imageUrl', 'images', 'location', 'description', 'isPromoted', 'phone', 'ownerEmail'])
                    && isValidAd(request.resource.data);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }
  }
}
